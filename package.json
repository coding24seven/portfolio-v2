    "react-dom": "^19.2.4",
    "react-router": "^7.13.2",
    "styled-components": "^6.3.12"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@emotion/babel-plugin": "^11.13.5",
    "@eslint/js": "^9.39.4",
    "@rolldown/plugin-babel": "^0.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.12.0",
