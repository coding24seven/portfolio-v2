    "docker:start": "docker/start.sh",
    "opencode:web": "opencode web --port 4096 --hostname 0.0.0.0"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "motion": "^12.38.0",
